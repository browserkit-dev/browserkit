{
  "name": "@browserkit/core",
  "version": "0.1.0",
  "description": "Core framework for building site-specific MCP servers over authenticated browser sessions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "bin": {
    "browserkit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "postinstall": "playwright install chromium --with-deps || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "pino": "^9.6.0",
    "playwright": "^1.51.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "optionalDependencies": {
    "@browserkit/adapter-hackernews": "workspace:*"
  }
}
